local isLocked = false
local camLockConnection = nil

local function getTargetPlayer()
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= localPlayer then
			local backpack = player:FindFirstChild("Backpack")
			local char = player.Character
			local hasKnife = (backpack and backpack:FindFirstChild("Knife")) or (char and char:FindFirstChild("Knife"))
			if hasKnife and char and char:FindFirstChild("HumanoidRootPart") then
				local humanoid = char:FindFirstChildOfClass("Humanoid")
				if humanoid and humanoid.Health > 0 then
					return char.HumanoidRootPart
				end
			end
		end
	end
	return nil
end

local function enableCamLock()
	camLockConnection = RunService.RenderStepped:Connect(function()
		camera = workspace.CurrentCamera
		local target = getTargetPlayer()
		if target then
			camera.CFrame = CFrame.new(camera.CFrame.Position, target.Position)
		end
	end)
end

local function disableCamLock()
	if camLockConnection then
		camLockConnection:Disconnect()
		camLockConnection = nil
	end
end

toggleButton.MouseButton1Click:Connect(function()
	isLocked = not isLocked
	local targetColor = isLocked and Color3.fromRGB(45, 175, 85) or Color3.fromRGB(235, 60, 60)
	local targetText = isLocked and "LOCK: ON" or "LOCK: OFF"
	if isLocked then
		enableCamLock()
	else
		disableCamLock()
	end
	toggleButton.Text = targetText
	TweenService:Create(toggleButton, TweenInfo.new(0.15), {BackgroundColor3 = targetColor}):Play()
end)
